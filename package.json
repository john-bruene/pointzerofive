		"@types/node": "^25.3.2",
		"@types/topojson-client": "^3.1.5",
		"eslint": "^10.0.2",
		"eslint-plugin-svelte": "^3.15.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.1",
